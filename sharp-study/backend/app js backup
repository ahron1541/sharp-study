require('dotenv').config();
const express = require('express');
const cors = require('cors');
const helmet = require('helmet');
const { sanitizeInput } = require('./middleware/sanitize.middleware');
const { generalLimiter, speedLimiter } = require('./middleware/rateLimit.middleware');

const authRoutes      = require('./features/auth/auth.routes');
const documentsRoutes = require('./features/documents/documents.routes');
const aiRoutes        = require('./features/ai/ai.routes');
const flashcardsRoutes= require('./features/flashcards/flashcards.routes');
const quizRoutes      = require('./features/quiz/quiz.routes');
const adminRoutes     = require('./features/admin/admin.routes');

const app = express();

// Security headers (helmet sets ~15 HTTP headers automatically)
app.use(helmet());

// CORS — only allow your frontend domain
app.use(cors({
  origin: [
  'http://localhost:5173',
  'http://localhost:5174', // <-- Add your new port here!
  'https://sharp-study.vercel.app', 
],
  credentials: true,
}));

app.use(express.json({ limit: '1mb' }));
app.use(express.urlencoded({ extended: true, limit: '1mb' }));

// Apply sanitization to ALL incoming requests
app.use(sanitizeInput);

// Apply global rate limiting + throttling
app.use(generalLimiter);
app.use(speedLimiter);

app.use('/api/auth',       authRoutes);
app.use('/api/documents',  documentsRoutes);
app.use('/api/ai',         aiRoutes);
app.use('/api/flashcards', flashcardsRoutes);
app.use('/api/quiz',       quizRoutes);
app.use('/api/admin',      adminRoutes);

app.get('/health', (req, res) => res.json({ status: 'ok' }));

// Global error handler
app.use((err, req, res, next) => {
  console.error(err.stack);
  res.status(500).json({ error: 'Something went wrong. Please try again.' });
});

const PORT = process.env.PORT || 5000;
app.listen(PORT, () => console.log(`Server running on port ${PORT}`));